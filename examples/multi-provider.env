# Hyper Claude Code — Multi-Provider Setup
# Route different model tiers to different providers.
# Opus → powerful cloud model, Sonnet → free mid-tier, Haiku → fast local.

NVIDIA_NIM_API_KEY="nvapi-your-key"
OPENROUTER_API_KEY="sk-or-your-key"

# Per-tier routing
MODEL_OPUS="nvidia_nim/moonshotai/kimi-k2.5"
MODEL_SONNET="open_router/deepseek/deepseek-r1-0528:free"
MODEL_HAIKU="ollama/llama3.1"
MODEL="nvidia_nim/z-ai/glm4.7"

# Enable thinking for complex tiers
ENABLE_MODEL_THINKING=true
ENABLE_HAIKU_THINKING=false

# Auth
ANTHROPIC_AUTH_TOKEN="your-secret-token"
