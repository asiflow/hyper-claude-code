# Hyper Claude Code — Full Middleware Setup
# All middleware plugins enabled with recommended defaults.

# Provider
NVIDIA_NIM_API_KEY="nvapi-your-key"
MODEL="nvidia_nim/z-ai/glm4.7"
ANTHROPIC_AUTH_TOKEN="your-secret-token"

# Middleware pipeline (master switch)
ENABLE_MIDDLEWARE_PIPELINE=true

# Cost Intelligence — track spending, enforce budget
ENABLE_COST_TRACKING=true
MAX_SESSION_COST_USD=10.00

# Response Caching — cache identical requests
ENABLE_RESPONSE_CACHE=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_ENTRIES=1000

# Provider Failover — auto-switch on failure
ENABLE_PROVIDER_FAILOVER=true
FAILOVER_ERROR_THRESHOLD=0.5
FAILOVER_WINDOW_SIZE=10
FAILOVER_COOLDOWN_SECONDS=30

# Request Logging — full audit trail
ENABLE_REQUEST_LOGGING=true
STORAGE_DB_PATH="~/.fcc/hcc.db"
