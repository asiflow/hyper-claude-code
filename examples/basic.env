# Hyper Claude Code — Basic Setup
# The simplest configuration: one provider, local-only access.

# Choose one provider and set its key
NVIDIA_NIM_API_KEY="nvapi-your-key"
MODEL="nvidia_nim/z-ai/glm4.7"

# Auth token — protects your proxy
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ANTHROPIC_AUTH_TOKEN="your-secret-token"
