# Hyper Claude Code — Fully Local Setup
# No cloud APIs, no API keys, complete privacy. Your code never leaves your machine.

# Use Ollama (or LM Studio / llama.cpp)
OLLAMA_BASE_URL="http://localhost:11434"
MODEL="ollama/llama3.1"

# No auth needed for local-only (default host is 127.0.0.1)
ANTHROPIC_AUTH_TOKEN=""

# Optional: local voice transcription
VOICE_NOTE_ENABLED=false
WHISPER_DEVICE="cpu"
WHISPER_MODEL="base"
